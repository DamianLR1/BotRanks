# ==========================================
# CONFIGURACIÓN DEL BOT - COPIA ESTE ARCHIVO
# Renómbralo a ".env" y completa los valores
# ==========================================

# Token del bot (Discord Developer Portal)
DISCORD_TOKEN=

# ID del servidor donde se instala el bot
GUILD_ID=

# ID del canal donde se publica el ranking
RANKING_CHANNEL_ID=

# ID del canal donde llegan los mensajes del webhook con los puntos
CHANNEL_ID=

# ID del mensaje a partir del cual empezar a contar puntos
# (el bot ignorará todos los mensajes anteriores a este ID)
RESET_MESSAGE_ID=

# ==========================================
# BASE DE DATOS POSTGRESQL
# ==========================================
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=5432
