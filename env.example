# ==========================================
# DISCORD
# ==========================================
DISCORD_TOKEN=tu_token_aqui
GUILD_ID=id_de_tu_servidor

# Canal donde el webhook de MC publica los puntos
CHANNEL_ID=id_del_canal_webhook

# Canal donde se publica el ranking en vivo y los anuncios de eventos
RANKING_CHANNEL_ID=id_del_canal_ranking

# Canal donde se publican los podios de cierre de eventos (embed permanente)
EVENTS_CHANNEL_ID=id_del_canal_eventos

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
PGHOST=host_de_tu_db
PGUSER=usuario_db
PGPASSWORD=contraseña_db
PGDATABASE=nombre_db
PGPORT=5432

# ==========================================
# CONFIGURACIÓN OPCIONAL
# ==========================================

# ID del mensaje desde donde el bot empieza a contar puntos al iniciar por primera vez
RESET_MESSAGE_ID=id_del_mensaje_de_inicio

# Zona horaria para el reporte diario (medianoche local)
# Ejemplos: America/Argentina/Buenos_Aires | Europe/Madrid | America/Mexico_City
TIMEZONE=America/Argentina/Buenos_Aires
